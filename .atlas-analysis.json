  "keyFeatures": [
    "Immersive Reader Mode: overlays the YouTube AI Chat panel exactly over the video player",
    "Auto-activate: enters Reader Mode automatically on videos with AI capabilities",
    "Initial Prompts: configurable automatic text submitted to the AI when a video opens",
    "Smart Timestamps: clicking AI-suggested timestamps seamlessly switches back to video mode",
    "Zero-dependency Vanilla JS: no bundlers, no frameworks, pure content script architecture",
    "Event-driven architecture using a strict Pub/Sub EventBus pattern",
    "DOM abstraction via YouTubeFacade to isolate selector fragility",
    "Chrome sync storage for persistent cross-device settings"
  ],
  "publicApiSurface": [
    "EventBus.on(event, callback)",
    "EventBus.off(event, callback)",
    "EventBus.emit(event, payload)",
    "StateManager.isActive",
    "StateManager.settings",
    "StateManager.setSettings(newSettings)",
    "StateManager.setActive(isActive)",
